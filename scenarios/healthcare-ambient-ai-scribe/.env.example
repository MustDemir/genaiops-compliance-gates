# ================================================================
# GenAIOps PoC — Local Development Secrets (TEMPLATE)
# ================================================================
# Copy to .env and fill in values:
#   cp .env.example .env
#
# .env is gitignored — never commit real secrets.
# ================================================================

# --- PostgreSQL Evidence Store ---
POSTGRES_DB=genaiops
POSTGRES_USER=genaiops
POSTGRES_PASSWORD=<choose-a-local-password>

# --- Grafana Admin ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=<choose-a-local-password>
