# EditorConfig — https://editorconfig.org
# Top-most config in this repository
root = true

# Defaults — apply to all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python — 4 spaces (PEP 8)
[*.py]
indent_size = 4

# Makefile requires literal tabs
[Makefile]
indent_style = tab

# Shell scripts
[*.sh]
indent_size = 2

# Rego policies
[*.rego]
indent_size = 4

# YAML / JSON / Markdown — 2-space defaults already apply
[*.{yaml,yml}]
indent_size = 2

# Markdown — preserve trailing whitespace (used for line breaks)
[*.md]
trim_trailing_whitespace = false

# Diffs
[*.{patch,diff}]
trim_trailing_whitespace = false
insert_final_newline = false
